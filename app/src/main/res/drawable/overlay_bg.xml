<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow border (gold) -->
    <item>
        <shape>
            <solid android:color="#33FFB800" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Dark glass body -->
    <item android:all="1dp">
        <shape>
            <gradient
                android:startColor="#F2111827"
                android:endColor="#F20D1423"
                android:angle="145" />
            <stroke android:width="1dp" android:color="#FFB800" />
            <corners android:radius="17dp" />
        </shape>
    </item>
</layer-list>
