<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_bg"
    android:elevation="8dp">

    <!-- Drag Handle / Header -->
    <LinearLayout
        android:id="@+id/overlayHeader"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_panel"
        android:paddingStart="10dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚔ OSRS BOT"
            android:textColor="@color/gold"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Minimise -->
        <ImageButton
            android:id="@+id/btnMinimize"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/btn_overlay_bg"
            android:contentDescription="Minimize"
            android:src="@android:drawable/arrow_up_float"
            android:tint="@color/text_primary"
            android:scaleType="centerInside"
            android:layout_marginEnd="4dp" />

        <!-- Stop -->
        <ImageButton
            android:id="@+id/btnOverlayStop"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/btn_red_bg"
            android:contentDescription="Stop bot"
            android:src="@android:drawable/ic_media_pause"
            android:tint="@color/text_primary"
            android:scaleType="centerInside"
            android:layout_marginEnd="4dp" />

        <!-- Start -->
        <ImageButton
            android:id="@+id/btnOverlayStart"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/btn_green_bg"
            android:contentDescription="Start bot"
            android:src="@android:drawable/ic_media_play"
            android:tint="@color/text_primary"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Stats Body -->
    <LinearLayout
        android:id="@+id/overlayBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="5dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Script" android:textColor="@color/text_muted" android:textSize="11sp" />
            <TextView android:id="@+id/tvOvScript" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/gold_light" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="5dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Actions" android:textColor="@color/text_muted" android:textSize="11sp" />
            <TextView android:id="@+id/tvOvActions" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/gold_light" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="5dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="XP Gained" android:textColor="@color/text_muted" android:textSize="11sp" />
            <TextView android:id="@+id/tvOvXP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/gold_light" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="5dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="GP/hr" android:textColor="@color/text_muted" android:textSize="11sp" />
            <TextView android:id="@+id/tvOvGP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/green" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="5dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Runtime" android:textColor="@color/text_muted" android:textSize="11sp" />
            <TextView android:id="@+id/tvOvRuntime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00:00" android:textColor="@color/gold_light" android:textSize="11sp" android:textStyle="bold" android:fontFamily="monospace" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Status" android:textColor="@color/text_muted" android:textSize="11sp" />
            <TextView android:id="@+id/tvOvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Idle" android:textColor="@color/text_muted" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- Current action -->
        <TextView
            android:id="@+id/tvOvAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting…"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:maxLines="2"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
