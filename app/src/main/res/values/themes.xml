<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OSRSBot" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/gold_dim</item>
        <item name="colorOnPrimary">@color/text_dark</item>
        <item name="colorSecondary">@color/green</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_void</item>
        <item name="android:navigationBarColor">@color/bg_void</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Card defaults -->
        <item name="materialCardViewStyle">@style/CardStyle</item>
    </style>

    <style name="Theme.OSRSBot.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Material card default style -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardElevation">8dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Section label text style -->
    <style name="SectionLabel">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Value text in stat rows -->
    <style name="StatValue">
        <item name="android:textColor">@color/gold_light</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
